{
  "version": 2,

  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "250mb"
      }
    }
  ],

  "routes": [
    {
      "src": "/static/(.*)",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      },
      "dest": "/api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.py"
    }
  ],

  "env": {
    "DJANGO_SETTINGS_MODULE": "gdgProject.settings.vercel"
  },

  "build": {
    "env": {
      "DJANGO_SETTINGS_MODULE": "gdgProject.settings.vercel"
    }
  }
}

