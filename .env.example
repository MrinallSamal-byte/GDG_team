# ═══════════════════════════════════════════════════════════════════════════════
# CampusArena — Environment Configuration
# Copy to .env and fill in production values.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Django Core ──────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=gdgProject.settings.dev
SECRET_KEY=change-me-to-a-real-secret-key-use-django-get-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ─────────────────────────────────────────────────────────────────
DB_ENGINE=django.db.backends.postgresql
DB_NAME=campusarena
DB_USER=campusarena
DB_PASSWORD=changeme
DB_HOST=localhost
DB_PORT=5432

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Cache ────────────────────────────────────────────────────────────────────
CACHE_BACKEND=django.core.cache.backends.redis.RedisCache
CACHE_LOCATION=redis://localhost:6379/1

# ── Email ────────────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@campusarena.dev

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
