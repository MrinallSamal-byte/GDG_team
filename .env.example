# ═══════════════════════════════════════════════════════════════════════════════
# CampusArena — Environment Configuration
# Copy this file to .env and fill in real values before running.
# Never commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Django Core ───────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=gdgProject.settings.dev
SECRET_KEY=change-me-to-a-real-secret-key-use-django-get-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (MySQL — local / Docker) ────────────────────────────────────────
DB_ENGINE=django.db.backends.postgresql
DB_NAME=campusarena
DB_USER=campusarena
DB_PASSWORD=changeme
DB_HOST=localhost
DB_PORT=3306

# ── Database (PostgreSQL — Vercel / Railway / Render / Heroku) ───────────────
# Set this variable instead of the MySQL vars above when deploying to Vercel.
# Get a free PostgreSQL URL from Neon (https://neon.tech) or
# Supabase (https://supabase.com):
#   postgresql://user:password@host:5432/dbname?sslmode=require
# DATABASE_URL=postgresql://postgres:your-password@db.your-ref.supabase.co:5432/postgres


# ── Redis (required for Channels WebSockets in dev/prod) ─────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_BACKEND=django.core.cache.backends.redis.RedisCache
CACHE_LOCATION=redis://localhost:6379/1

# ── Email ─────────────────────────────────────────────────────────────────────
# Use console backend in dev (prints emails to terminal)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# In production, switch to SMTP:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@campusarena.dev

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── OTP expiry ────────────────────────────────────────────────────────────────
OTP_EXPIRY_SECONDS=600

# ── [E1] Razorpay Payment Gateway ─────────────────────────────────────────────
# Get these from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ── [E6] OAuth — Google ────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: http://localhost:8000/auth/social/google/login/callback/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── [E6] OAuth — GitHub ────────────────────────────────────────────────────────
# Create app at https://github.com/settings/applications/new
# Callback URL: http://localhost:8000/auth/social/github/login/callback/
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ── [E15] AI matching — optional Anthropic API key ────────────────────────────
# Needed only if you want Claude-powered natural-language match explanations.
# Install: pip install anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# ── Site URL (used in certificate QR codes) ───────────────────────────────────
SITE_URL=http://localhost:8000
